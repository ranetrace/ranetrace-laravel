{
    "name": "usesorane/sorane-laravel",
    "description": "This package provides the integration for Ranetrace, a tool for monitoring your Laravel applications.",
    "keywords": [
        "ranetrace",
        "laravel",
        "ranetrace-laravel"
    ],
    "homepage": "https://github.com/usesorane/sorane-laravel",
    "license": "MIT",
    "authors": [
        {
            "name": "Ranetrace",
            "email": "contact@ranetrace.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "illuminate/support": "^11.0||^12.0",
        "jaybizzle/crawler-detect": "^1.3"
    },
    "require-dev": {
        "larastan/larastan": "^2.9",
        "laravel/boost": "^2.0",
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.1.1||^7.10.0",
        "orchestra/testbench": "^9.0.0||^8.22.0",
        "pestphp/pest": "^2.34",
        "pestphp/pest-plugin-arch": "^2.7",
        "pestphp/pest-plugin-laravel": "^2.3",
        "phpstan/extension-installer": "^1.3",
        "phpstan/phpstan-deprecation-rules": "^1.1",
        "phpstan/phpstan-phpunit": "^1.3"
    },
    "suggest": {
        "laravel/mcp": "Required for MCP server functionality (^0.5)"
    },
    "autoload": {
        "psr-4": {
            "Sorane\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sorane\\Laravel\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-update-cmd": [
            "@php artisan boost:update --ansi"
        ],
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Sorane\\Laravel\\SoraneServiceProvider"
            ],
            "aliases": {
                "Sorane": "Sorane\\Laravel\\Facades\\Sorane"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
