includes:
    - phpstan-baseline.neon

parameters:
    paths:
        - src
    level: 5
    ignoreErrors:
        # Cache::store() is typed as the Repository contract, which does not
        # declare lock(); locking comes from the LockProvider contract, which
        # the array/redis/database/etc. stores all implement. Known larastan
        # limitation — not a real error.
        -
            message: '#Call to an undefined method .*::lock\(\)#'
            path: src/Services/RanetraceBatchBuffer.php
        # Auth::user() is typed as the framework's base User; the host app's
        # User model defines the `email` column. buildErrorPayload() runs
        # inside report()'s try/catch, so a model lacking `email` cannot break
        # the host application.
        -
            message: '#Access to an undefined property .*::\$email#'
            path: src/Ranetrace.php
