includes:
    - phpstan-baseline.neon

parameters:
    paths:
        - src
    level: 5
    # Some inline @phpstan-ignore hints are version-conditional: larastan narrows
    # the host framework's stubs differently across Laravel 12/13, so an ignore
    # that matches on one version is unmatched on another. Don't fail the build on
    # an unmatched ignore (the CI matrix runs both versions).
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        # Cache::store() is typed as the Repository contract, which does not
        # declare lock(); locking comes from the LockProvider contract, which
        # the array/redis/database/etc. stores all implement. Known larastan
        # limitation — not a real error.
        -
            message: '#Call to an undefined method .*::lock\(\)#'
            path: src/Services/RanetraceBatchBuffer.php
